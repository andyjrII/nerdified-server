# Database Configuration
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://postgres:password@localhost:5432/nerdified_db
DATABASE_URL=postgresql://user:password@localhost:5432/nerdified_db

# JWT Authentication Secrets
# Generate strong random strings for these (at least 32 characters)
# You can use: openssl rand -base64 32
AT_SECRET_KEY=your_access_token_secret_key_here_min_32_chars
RT_SECRET_KEY=your_refresh_token_secret_key_here_min_32_chars

# Frontend Configuration
# The base URL of your frontend application (for CORS)
# Development: http://localhost:3101
# Production: https://yourdomain.com
FRONTEND_BASE_URL=http://localhost:3101

# Cloudinary Configuration (for image/file uploads)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# LiveKit Configuration (for live video + audio sessions)
# Point LIVEKIT_WS_URL to your deployed LiveKit server (e.g. wss://livekit.yourdomain.com)
LIVEKIT_WS_URL=wss://your-livekit-server
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Paystack Configuration (for payment verification AND tutor payout transfers)
# Get your secret key from the Paystack dashboard: https://dashboard.paystack.com/#/settings/developers
# Use the test key (sk_test_...) in development and the live key (sk_live_...) in production.
# The same key powers tutor payout disbursement via Paystack Transfers. For
# async transfer confirmation, add a webhook in the Paystack dashboard pointing
# to:  <API_BASE_URL>/api/payouts/webhook/paystack
# (transfer.success / transfer.failed / transfer.reversed events).
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Brevo Configuration (for transactional email / notifications)
# Create an API key at https://app.brevo.com/settings/keys/api
# BREVO_SENDER_EMAIL must be a verified sender/domain in your Brevo account.
# If these are unset, the app still runs — emails are skipped (logged), not sent.
BREVO_API_KEY=xkeysib-your_brevo_api_key
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=Nerdified

# Payouts Configuration
# Platform commission as a fraction (0–1) deducted from tutor earnings on payout.
# Example: 0.15 = platform keeps 15%, tutor receives 85%. Defaults to 0.15 if unset/invalid.
PLATFORM_COMMISSION_RATE=0.15

# Google OAuth (optional — "Continue with Google" sign-in)
# Create an OAuth 2.0 Client ID (Web application) at
# https://console.cloud.google.com/apis/credentials and add
# GOOGLE_CALLBACK_URL to its authorized redirect URIs.
# If unset, Google sign-in is disabled and the button redirects back with an error.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3100/api/auth/google/callback

# Session Recording (optional — LiveKit room-composite egress)
# Recordings are written to S3-compatible storage (AWS S3, Cloudflare R2,
# Backblaze B2, MinIO…). Leave unset to disable recording; the record button
# then reports "not configured" and everything else still works.
# RECORDING_S3_ENDPOINT is only needed for non-AWS providers.
# RECORDING_PUBLIC_BASE_URL (optional) is prepended to the file path to build
# the public recordingUrl (e.g. a CDN or public bucket URL); otherwise the
# storage location reported by the egress is used.
RECORDING_S3_KEY_ID=your_s3_access_key_id
RECORDING_S3_SECRET=your_s3_secret_access_key
RECORDING_S3_BUCKET=your_recordings_bucket
RECORDING_S3_REGION=us-east-1
# RECORDING_S3_ENDPOINT=https://your-s3-compatible-endpoint
# RECORDING_PUBLIC_BASE_URL=https://recordings.yourdomain.com

# Class Reminders
# How many minutes before a session starts the reminder scheduler notifies
# the tutor and booked students (in-app + email). Defaults to 60 if unset.
CLASS_REMINDER_LEAD_MINUTES=60

# Server Configuration
# Backend server port (default: 3100)
PORT=3100
